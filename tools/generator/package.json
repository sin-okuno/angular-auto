{
  "name": "screen-code-generator",
  "version": "1.0.0",
  "description": "Deterministic Angular + NgRx code generator driven by Markdown screen specifications.",
  "private": true,
  "type": "module",
  "scripts": {
    "spec:convert": "tsx src/index.ts convert",
    "screen:validate": "tsx src/index.ts validate",
    "code:generate": "tsx src/index.ts generate",
    "generate:screen": "tsx src/index.ts all",
    "generate:dry-run": "tsx src/index.ts dry-run",
    "generate:check": "tsx src/index.ts check",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "change-case": "^5.4.4",
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "diff": "^7.0.0",
    "fast-glob": "^3.3.2",
    "fs-extra": "^11.2.0",
    "handlebars": "^4.7.8",
    "marked": "^14.1.3",
    "prettier": "^3.3.3",
    "yaml": "^2.5.1"
  },
  "devDependencies": {
    "@types/diff": "^7.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "~5.5.2"
  }
}
