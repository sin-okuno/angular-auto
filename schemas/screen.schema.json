{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/screen.schema.json",
  "title": "ScreenDefinition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "screen",
    "permissions",
    "operations",
    "search",
    "tree",
    "detail",
    "apis",
    "store",
    "types",
    "actions",
    "unsavedChanges",
    "concurrentUpdate",
    "displayRules",
    "validations",
    "tests"
  ],
  "properties": {
    "version": { "type": "integer", "enum": [1] },
    "screen": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "route", "pageType", "featureName"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "name": { "type": "string", "minLength": 1 },
        "route": { "type": "string", "minLength": 1 },
        "pageType": { "type": "string", "enum": ["tree-detail"] },
        "featureName": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
      }
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "description"],
        "properties": {
          "code": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
          "description": { "type": "string" }
        }
      }
    },
    "operations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "description", "requiresPermission"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-zA-Z0-9]*$" },
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "requiresPermission": { "type": ["string", "null"] }
        }
      }
    },
    "search": {
      "type": "object",
      "additionalProperties": false,
      "required": ["conditionType", "fields"],
      "properties": {
        "conditionType": { "type": "string", "minLength": 1 },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "label", "type", "required"],
            "properties": {
              "name": { "type": "string", "pattern": "^[a-z][a-zA-Z0-9]*$" },
              "label": { "type": "string" },
              "type": { "type": "string", "minLength": 1 },
              "required": { "type": "boolean" }
            }
          }
        }
      }
    },
    "tree": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodeType", "idField", "detailIdField", "displayFields", "rules"],
      "properties": {
        "nodeType": { "type": "string", "minLength": 1 },
        "idField": { "type": "string", "minLength": 1 },
        "detailIdField": { "type": "string", "minLength": 1 },
        "displayFields": { "type": "array", "items": { "type": "string" } },
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "description"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "detail": {
      "type": "object",
      "additionalProperties": false,
      "required": ["modelType", "fields", "formStateManagement"],
      "properties": {
        "modelType": { "type": "string", "minLength": 1 },
        "formStateManagement": { "type": "string", "enum": ["local", "store"] },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "label", "type", "required", "editable"],
            "properties": {
              "name": { "type": "string", "pattern": "^[a-z][a-zA-Z0-9]*$" },
              "label": { "type": "string" },
              "type": { "type": "string", "minLength": 1 },
              "required": { "type": "boolean" },
              "editable": { "type": "boolean" }
            }
          }
        }
      }
    },
    "apis": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "method", "path", "requestType", "responseType", "description"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-zA-Z0-9]*$" },
          "name": { "type": "string" },
          "method": { "type": "string", "enum": ["GET", "POST", "PUT", "DELETE", "PATCH"] },
          "path": { "type": "string", "pattern": "^/" },
          "requestType": { "type": ["string", "null"] },
          "responseType": { "type": ["string", "null"] },
          "description": { "type": "string" }
        }
      }
    },
    "store": {
      "type": "object",
      "additionalProperties": false,
      "required": ["featureKey", "fields"],
      "properties": {
        "featureKey": { "type": "string", "pattern": "^[a-z][a-zA-Z0-9]*$" },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "type", "initial", "description"],
            "properties": {
              "name": { "type": "string", "pattern": "^[a-z][a-zA-Z0-9]*$" },
              "type": { "type": "string", "minLength": 1 },
              "initial": { "type": "string", "minLength": 1 },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "types": {
      "type": "object",
      "additionalProperties": false,
      "required": ["api", "view", "action"],
      "properties": {
        "api": { "$ref": "#/definitions/typeList" },
        "view": { "$ref": "#/definitions/typeList" },
        "action": { "$ref": "#/definitions/typeList" }
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "category",
          "payloadType",
          "api",
          "successAction",
          "failureAction",
          "relatedOperation",
          "storeUpdates"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-zA-Z0-9]*$" },
          "name": { "type": "string", "minLength": 1 },
          "category": { "type": "string", "minLength": 1 },
          "payloadType": { "type": ["string", "null"] },
          "api": { "type": ["string", "null"] },
          "successAction": { "type": ["string", "null"] },
          "failureAction": { "type": ["string", "null"] },
          "relatedOperation": { "type": ["string", "null"] },
          "storeUpdates": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["field", "value"],
              "properties": {
                "field": { "type": "string", "minLength": 1 },
                "value": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "unsavedChanges": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "dirtySource", "operations", "confirmMessage"],
      "properties": {
        "enabled": { "type": "boolean" },
        "dirtySource": { "type": "string", "minLength": 1 },
        "operations": { "type": "array", "items": { "type": "string" } },
        "confirmMessage": { "type": "string", "minLength": 1 }
      }
    },
    "concurrentUpdate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "revisionField", "statusCode", "errorCode", "message"],
      "properties": {
        "enabled": { "type": "boolean" },
        "revisionField": { "type": "string", "minLength": 1 },
        "statusCode": { "type": "integer" },
        "errorCode": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "displayRules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "condition", "behavior"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "condition": { "type": "string" },
          "behavior": { "type": "string" }
        }
      }
    },
    "validations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["field", "rule", "message"],
        "properties": {
          "field": { "type": "string", "minLength": 1 },
          "rule": { "type": "string", "minLength": 1 },
          "message": { "type": "string" }
        }
      }
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "target", "description"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "target": { "type": "string", "minLength": 1 },
          "description": { "type": "string" }
        }
      }
    }
  },
  "definitions": {
    "typeList": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "properties"],
        "properties": {
          "name": { "type": "string", "pattern": "^[A-Z][A-Za-z0-9]*$" },
          "properties": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "type", "optional", "description"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "type": { "type": "string", "minLength": 1 },
                "optional": { "type": "boolean" },
                "description": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
